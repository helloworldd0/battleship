<Window x:Class="Battleship.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Battleship.Client.Controls"
        Title="Морской бой"
        Height="720" Width="980"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText"
                   Grid.Row="0"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="16"
                   Margin="0,0,0,12"
                   Text="Добро пожаловать"/>

        <!-- Login -->
        <Border x:Name="LoginPanel"
                Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                CornerRadius="8"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="360">
            <StackPanel>
                <TextBlock Text="Вход / Регистрация"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <TextBlock Text="Имя пользователя" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Height="32" Margin="0,0,0,12"/>

                <TextBlock Text="Пароль" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,0,0,16"/>

                <TextBlock x:Name="LoginErrorText"
                           Foreground="{StaticResource HighlightBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Войти"
                            Width="120" Height="36" Margin="0,0,8,0"
                            Click="Login_Click"/>
                    <Button Content="Регистрация"
                            Width="120" Height="36"
                            Click="Register_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Lobby -->
        <Border x:Name="LobbyPanel"
                Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                CornerRadius="8"
                Padding="32"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="WelcomeText"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <Button x:Name="FindGameButton"
                        Content="Найти игру"
                        Width="200" Height="40"
                        FontSize="16"
                        Click="FindGame_Click"/>

                <Button Content="Выйти из аккаунта"
                        Width="200" Height="32"
                        Margin="0,16,0,0"
                        Click="Logout_Click"/>
            </StackPanel>
        </Border>

        <!-- Placement -->
        <Grid x:Name="PlacementPanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <TextBlock Text="Ваше поле — расставьте корабли"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <controls:BoardControl x:Name="PlacementBoard"
                                       Width="400" Height="400"
                                       ShowShips="True"
                                       IsInteractive="False"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock x:Name="PlacementInfoText"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <Button Content="Случайная расстановка"
                        Height="36" Margin="0,0,0,8"
                        Click="RandomPlacement_Click"/>

                <Button x:Name="ConfirmPlacementButton"
                        Content="Подтвердить расстановку"
                        Height="36"
                        IsEnabled="False"
                        Click="ConfirmPlacement_Click"/>
            </StackPanel>
        </Grid>

        <!-- Battle -->
        <Grid x:Name="BattlePanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <TextBlock Text="Ваш флот"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <controls:BoardControl x:Name="MyBoard"
                                       Width="340" Height="340"
                                       ShowShips="True"
                                       IsInteractive="False"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="Поле противника"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <controls:BoardControl x:Name="EnemyBoard"
                                       Width="340" Height="340"
                                       ShowShips="False"
                                       IsInteractive="True"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                <Button Content="Сдаться"
                        Width="140" Height="32"
                        Click="Surrender_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
