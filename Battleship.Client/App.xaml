<Application x:Class="Battleship.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#16213e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0f3460"/>
        <SolidColorBrush x:Key="HighlightBrush" Color="#e94560"/>
        <SolidColorBrush x:Key="TextBrush" Color="#eaeaea"/>
        <SolidColorBrush x:Key="WaterBrush" Color="#0a3d62"/>
        <SolidColorBrush x:Key="ShipBrush" Color="#576574"/>
        <SolidColorBrush x:Key="HitBrush" Color="#c0392b"/>
        <SolidColorBrush x:Key="MissBrush" Color="#74b9ff"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Application.Resources>
</Application>
